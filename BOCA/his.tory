 3963  cat << 'EOF' > /tmp/migrate_mvnn.py\nimport re\n\nwith open("mlca/mvnn_mip_torch_new.py", "r") as f:\n    text = f.read()\n\n# Imports\ntext = re.sub(r'import docplex\.mp\.model as cpx', 'import gurobipy as gp\nfrom gurobipy import GRB', text)\ntext = re.sub(r'DOcplex', 'Gurobipy', text)\ntext = re.sub(r'docplex-doc', 'py_python_api_details', text)\n\n# Model\ntext = re.sub(r'cpx\.Model\(', 'gp.Model(', text)\ntext = re.sub(r'\.binary_var\(', '.addVar(vtype=GRB.BINARY, ', text)\ntext = re.sub(r'\.continuous_var\(', '.addVar(vtype=GRB.CONTINUOUS, ', text)\ntext = re.sub(r'self\.Mip\.add_constraint\(ct=(.*?), ctname=(.*?)\)', r'self.Mip.addConstr(\1, name=\2)', text)\ntext = re.sub(r'self\.Mip\.add_constraint\(ct=(.*?),(\s*)ctname=(.*?)\)', r'self.Mip.addConstr(\1,\2name=\3)', text)\ntext = re.sub(r'self\.Mip\.sum\(', 'gp.quicksum(', text)\ntext = re.sub(r'\.solution_value', '.X', text)\ntext = re.sub(r'self\.Mip\.maximize\((.*?)\)', r'self.Mip.setObjective(\1, GRB.MAXIMIZE)', text)\n\nwith open("mlca/mvnn_mip_torch_new.py", "w") as f:\n    f.write(text)\n\nprint("done")\nEOF
